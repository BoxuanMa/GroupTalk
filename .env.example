# --- Required ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grouptalk

# Generate a strong secret with: openssl rand -base64 48
# MUST be >=32 chars in production. Placeholder values are rejected at boot.
JWT_SECRET=replace-me-with-openssl-rand-base64-48

OPENAI_API_KEY=sk-...

# Public URL the browser uses to reach this server (Socket.IO + CORS).
# Local: http://localhost:3000  |  Prod: https://your-domain.example.com
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Optional: comma-separated allowed origins for Socket.IO CORS.
# Defaults to NEXT_PUBLIC_SOCKET_URL.
# CORS_ORIGIN=https://your-domain.example.com

# --- docker-compose only ---
# POSTGRES_PASSWORD=
